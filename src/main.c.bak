#include "yacfs.h"
#include <linux/kernel.h>
#include <linux/module.h>
#include <linux/fs_context.h>
#include <linux/fs_parser.h>
#include <linux/mount.h>
#include <linux/slab.h>
#include <linux/time.h>
#include <linux/cred.h>
#include <linux/namei.h>

MODULE_LICENSE("GPL");
MODULE_AUTHOR("Natalie Spiva, Darren Clift — AcreetionOS");
MODULE_DESCRIPTION("YAcFS v3 — Yet Another common File System (kernel module)");
MODULE_VERSION("3.0.0");

struct yacfs_fs_context {
    char *pool_path;
};

enum { OPT_POOL };

static const struct fs_parameter_spec yacfs_params[] = {
    fsparam_string("pool", OPT_POOL),
    {}
};

static int yacfs_parse_param(struct fs_context *fc, struct fs_parameter *param)
{
    struct yacfs_fs_context *ctx = fc->fs_private;
    struct fs_parse_result result;
    int opt, len;

    opt = fs_parse(fc, yacfs_params, param, &result);
    if (opt < 0)
        return opt;

    switch (opt) {
    case OPT_POOL:
        kfree(ctx->pool_path);
        ctx->pool_path = kstrdup(param->string, GFP_KERNEL);
        if (!ctx->pool_path)
            return -ENOMEM;
        len = strlen(ctx->pool_path);
        while (len > 1 && ctx->pool_path[len - 1] == '/')
            ctx->pool_path[--len] = '\0';
        break;
    }

    return 0;
}

static int yacfs_read_file(struct super_block *sb, const char *path, loff_t off, void *buf, size_t size)
{
    struct file *fp;
    loff_t pos = off;
    ssize_t ret;

    fp = filp_open(path, O_RDONLY, 0);
    if (IS_ERR(fp))
        return PTR_ERR(fp);

    ret = kernel_read(fp, buf, size, &pos);
    filp_close(fp, NULL);

    if (ret < 0)
        return ret;
    if (ret != size)
        return -EIO;

    return 0;
}

int yacfs_read_ino(struct super_block *sb, u64 ino, struct yacfs_inode_disk *disk)
{
    struct yacfs_sb_info *sbi = sb->s_fs_info;
    char *path;
    int ret;

    path = kmalloc(YACFS_POOL_MAX + 64, GFP_KERNEL);
    if (!path)
        return -ENOMEM;
    snprintf(path, YACFS_POOL_MAX + 64, "%s/meta/%020llu.ino", sbi->pool_path, ino);
    ret = yacfs_read_file(sb, path, 0, disk, sizeof(*disk));
    kfree(path);
    if (ret)
        return ret;
    if (disk->ino != ino)
        return -EIO;
    return 0;
}

int yacfs_read_ino_blocks(struct super_block *sb, u64 ino, struct yacfs_inode_disk *disk, __u64 **blocks)
{
    struct yacfs_sb_info *sbi = sb->s_fs_info;
    char *path;
    int ret;

    path = kmalloc(YACFS_POOL_MAX + 64, GFP_KERNEL);
    if (!path)
        return -ENOMEM;
    snprintf(path, YACFS_POOL_MAX + 64, "%s/meta/%020llu.ino", sbi->pool_path, ino);

    ret = yacfs_read_file(sb, path, 0, disk, sizeof(*disk));
    if (ret)
        goto out;
    if (disk->ino != ino) {
        ret = -EIO;
        goto out;
    }

    *blocks = NULL;
    if (disk->nblocks > 0) {
        size_t blist_sz = disk->nblocks * sizeof(__u64);
        *blocks = kmalloc(blist_sz, GFP_KERNEL);
        if (!*blocks) {
            ret = -ENOMEM;
            goto out;
        }
        ret = yacfs_read_file(sb, path, YACFS_INODE_SIZE, *blocks, blist_sz);
        if (ret) {
            kfree(*blocks);
            *blocks = NULL;
            goto out;
        }
    }
out:
    kfree(path);
    return ret;
}

int yacfs_read_block(struct super_block *sb, u64 hash, void *buf, size_t *size)
{
    struct yacfs_sb_info *sbi = sb->s_fs_info;
    char *path;
    struct yacfs_block_hdr hdr;
    int ret;

    path = kmalloc(YACFS_POOL_MAX + 64, GFP_KERNEL);
    if (!path)
        return -ENOMEM;
    snprintf(path, YACFS_POOL_MAX + 64, "%s/blocks/%016llx.blk", sbi->pool_path, hash);

    ret = yacfs_read_file(sb, path, 0, &hdr, sizeof(hdr));
    if (ret)
        goto out;

    if (hdr.magic != YACFS_BLOCK_MAGIC) {
        ret = -EIO;
        goto out;
    }
    if (hdr.orig_size > *size) {
        ret = -ENOSPC;
        goto out;
    }

    ret = yacfs_read_file(sb, path, YACFS_BLOCK_HDR_SIZE, buf, hdr.orig_size);
    if (ret)
        goto out;

    *size = hdr.orig_size;
out:
    kfree(path);
    return ret;
}

int yacfs_fill_inode(struct inode *inode, struct yacfs_inode_disk *disk)
{
    struct timespec64 ts;

    inode->i_ino = disk->ino;
    inode->i_mode = disk->mode;
    inode->i_uid = make_kuid(&init_user_ns, disk->uid);
    inode->i_gid = make_kgid(&init_user_ns, disk->gid);
    inode->i_size = disk->size;
    inode->i_blocks = disk->nblocks * (disk->block_size / 512);
    set_nlink(inode, disk->nlink);

    ts.tv_sec = disk->mtime;
    ts.tv_nsec = 0;
    inode_set_atime_to_ts(inode, ts);
    inode_set_mtime_to_ts(inode, ts);
    ts.tv_sec = disk->ctime;
    inode_set_ctime_to_ts(inode, ts);

    if (S_ISDIR(disk->mode)) {
        inode->i_op = &yacfs_dir_inode_ops;
        inode->i_fop = &yacfs_dir_ops;
    } else if (S_ISREG(disk->mode)) {
        inode->i_op = &yacfs_file_inode_ops;
        inode->i_fop = &yacfs_file_ops;
    }

    return 0;
}

static int yacfs_get_tree(struct fs_context *fc)
{
    struct yacfs_fs_context *ctx = fc->fs_private;
    struct super_block *sb;
    struct yacfs_sb_info *sbi;
    struct inode *root;
    struct yacfs_inode_disk disk;
    int ret;

    if (!ctx->pool_path) {
        errorf(fc, "YAcFS requires pool= option");
        return -EINVAL;
    }

    sb = sget_fc(fc, NULL, NULL);
    if (IS_ERR(sb))
        return PTR_ERR(sb);

    sbi = kzalloc(sizeof(*sbi), GFP_KERNEL);
    if (!sbi) {
        deactivate_locked_super(sb);
        return -ENOMEM;
    }

    strncpy(sbi->pool_path, ctx->pool_path, sizeof(sbi->pool_path) - 1);
    sbi->pool_path[sizeof(sbi->pool_path) - 1] = '\0';
    sb->s_fs_info = sbi;
    sb->s_op = &yacfs_super_ops;
    sb->s_magic = YACFS_SUPER_MAGIC;
    sb->s_blocksize = PAGE_SIZE;
    sb->s_blocksize_bits = PAGE_SHIFT;

    ret = yacfs_read_ino(sb, YACFS_ROOT_INO, &disk);
    if (ret) {
        kfree(sbi);
        sb->s_fs_info = NULL;
        deactivate_locked_super(sb);
        return ret;
    }

    root = new_inode(sb);
    if (!root) {
        kfree(sbi);
        sb->s_fs_info = NULL;
        deactivate_locked_super(sb);
        return -ENOMEM;
    }

    yacfs_fill_inode(root, &disk);

    sb->s_root = d_make_root(root);
    if (!sb->s_root) {
        kfree(sbi);
        sb->s_fs_info = NULL;
        deactivate_locked_super(sb);
        return -ENOMEM;
    }

    fc->root = dget(sb->s_root);
    return 0;
}

static void yacfs_free_fc(struct fs_context *fc)
{
    struct yacfs_fs_context *ctx = fc->fs_private;
    kfree(ctx->pool_path);
    kfree(ctx);
}

static const struct fs_context_operations yacfs_context_ops = {
    .parse_param = yacfs_parse_param,
    .get_tree    = yacfs_get_tree,
    .free        = yacfs_free_fc,
};

static int yacfs_init_fs_context(struct fs_context *fc)
{
    struct yacfs_fs_context *ctx = kzalloc(sizeof(*ctx), GFP_KERNEL);
    if (!ctx)
        return -ENOMEM;
    fc->fs_private = ctx;
    fc->ops = &yacfs_context_ops;
    return 0;
}

static void yacfs_kill_sb(struct super_block *sb)
{
    kill_anon_super(sb);
}

static struct file_system_type yacfs_fs_type = {
    .name              = "yacfs",
    .fs_flags          = FS_USERNS_MOUNT,
    .init_fs_context   = yacfs_init_fs_context,
    .parameters        = yacfs_params,
    .kill_sb           = yacfs_kill_sb,
    .owner             = THIS_MODULE,
};

static int __init yacfs_module_init(void)
{
    int ret = register_filesystem(&yacfs_fs_type);
    if (ret == 0)
        pr_info("YAcFS v3.0 loaded — kernel-mode filesystem\n");
    return ret;
}

static void __exit yacfs_module_exit(void)
{
    unregister_filesystem(&yacfs_fs_type);
    pr_info("YAcFS v3.0 unloaded\n");
}

module_init(yacfs_module_init);
module_exit(yacfs_module_exit);
